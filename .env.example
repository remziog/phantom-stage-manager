# Apex Cloud — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is managed by Lovable Cloud automatically; do not commit values.

# ─── Supabase (client-safe, publishable) ──────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Server-only (used by scripts/, edge functions, CI) ───────────────
# NEVER expose these in client code or commit real values.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── E2E test fixtures (CI only) ──────────────────────────────────────
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_OPERATOR_EMAIL=
E2E_OPERATOR_PASSWORD=
E2E_COMPANY_SLUG=e2e-test-co
E2E_COMPANY_NAME=E2E Test Co

# RLS multi-tenancy E2E (second tenant for isolation tests)
E2E_TENANT_B_EMAIL=
E2E_TENANT_B_PASSWORD=
E2E_TENANT_B_COMPANY_SLUG=e2e-tenant-b
E2E_TENANT_B_COMPANY_NAME=E2E Tenant B

# ─── Optional: preflight baseline resolution (see README) ─────────────
# PREFLIGHT_BASELINE_PATH=
# PREFLIGHT_FAIL_ON=regressions
# GITHUB_TOKEN=
